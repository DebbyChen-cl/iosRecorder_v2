  "codegen_output": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"Home_Switch_Kill\")\ndef test_Home_Switch_Kill(actions: DriverActions):\n    with step(\"[Action] Press Home button\"):\n        actions.press_home()\n    with step(\"[Action] Launch PhotoDirector\"):\n        actions.launch_app('com.cyberlink.photodirector')\n    with step(\"[Action] Terminate PhotoDirector\"):\n        actions.terminate_app('com.cyberlink.photodirector')\n    assert True\n"
