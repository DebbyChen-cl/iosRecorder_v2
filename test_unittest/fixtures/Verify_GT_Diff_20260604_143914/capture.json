  "codegen_output": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"Verify_GT_Diff\")\ndef test_Verify_GT_Diff(actions: DriverActions):\n    with step(\"[Verify] Capture 'screenshot' before screenshot\"):\n        actions.capture_for_preview('screenshot', 'before', AppiumBy.ACCESSIBILITY_ID, 'EditingImageView_ImageView')\n    with step(\"[Action] Tap ic_crop at (69.2%, 60.0%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'ic_crop', 69.2, 60.0, container_by=AppiumBy.ACCESSIBILITY_ID, container_value='EditViewControllerBottomBarCollectionView', container_w=320, container_h=72)\n    with step(\"[Action] Tap btn_perspective_s at (40.0%, 48.0%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'btn_perspective_s', 40.0, 48.0, container_by=AppiumBy.ACCESSIBILITY_ID, container_value='effectMenuCollectionViewPresenterCollectionView', container_w=124, container_h=65)\n    with step(\"[Action] Drag centerSlider (49.6%,51.6%) → slider (88.1%,50.0%)\"):\n        actions.drag_within_elements(AppiumBy.ACCESSIBILITY_ID, 'centerSlider', 49.6, 51.6, AppiumBy.ACCESSIBILITY_ID, 'slider', 88.1, 50.0, duration=1.0)\n    with step(\"[Action] Tap btn_ok_n at (88.9%, 44.4%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'btn_ok_n', 88.9, 44.4)\n    with step(\"[Verify] Capture 'screenshot' after screenshot\"):\n        actions.capture_for_preview('screenshot', 'after', AppiumBy.ACCESSIBILITY_ID, 'EditingImageView_ImageView', expected_result='different', threshold=0.95)\n    with step(\"[Verify] Capture 'Verify_GT_Diff_Step07' for GT comparison\"):\n        actions.capture_for_gt('Verify_GT_Diff_Step07', AppiumBy.ACCESSIBILITY_ID, 'EditingImageView_ImageView', threshold=0.95)\n    with step(\"[Verify] Screenshot comparisons\"):\n        actions.run_screenshot_comparisons(threshold=0.95)\n    assert True\n"
