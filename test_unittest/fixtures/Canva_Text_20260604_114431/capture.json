  "codegen_output": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"Canva_Text\")\ndef test_Canva_Text(actions: DriverActions):\n    with step(\"[Action] Tap btn_text_sub_menu_n at (76.0%, 64.0%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'btn_text_sub_menu_n', 76.0, 64.0, container_by=AppiumBy.ACCESSIBILITY_ID, container_value='effectMenuCollectionViewPresenterCollectionView', container_w=124, container_h=65)\n    with step(\"[Action] Tap //XCUIElementTypeImage at (38.1%, 50.8%)\"):\n        actions.tap_within_element(AppiumBy.XPATH, '//XCUIElementTypeImage', 38.1, 50.8)\n    with step(\"[Action] Type 'Text Test' into //XCUIElementTypeImage\"):\n        actions.type_text_by_locator(AppiumBy.XPATH, '//XCUIElementTypeImage', 'Text Test')\n    with step(\"[Action] Tap applyButton at (39.4%, 50.0%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'applyButton', 39.4, 50.0)\n    assert True\n"
