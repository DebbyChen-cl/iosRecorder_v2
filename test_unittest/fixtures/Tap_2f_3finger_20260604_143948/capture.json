  "codegen_output": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"Tap_2f_3finger\")\ndef test_Tap_2f_3finger(actions: DriverActions):\n    with step(\"[Action] Two finger tap Edit\"):\n        actions.two_finger_tap(actions.find_element(AppiumBy.ACCESSIBILITY_ID, 'Edit'))\n    with step(\"[Action] 3-finger tap btnBack\"):\n        actions.multi_finger_tap(actions.find_element(AppiumBy.ACCESSIBILITY_ID, 'btnBack'), fingers=3)\n    assert True\n"
