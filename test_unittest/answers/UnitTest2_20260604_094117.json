  "step_000_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Action] Tap btnMyCredit at (42.9%, 34.1%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'btnMyCredit', 42.9, 34.1, container_by=AppiumBy.ACCESSIBILITY_ID, container_value='launcherTrendyViewConfigCollectionView', container_w=294, container_h=119)\n    assert True\n",
  "step_001_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Action] Tap btnNotification at (75.0%, 52.4%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'btnNotification', 75.0, 52.4)\n    assert True\n",
  "step_002_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Action] Tap Back at (48.6%, 52.3%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'Back', 48.6, 52.3)\n    assert True\n",
  "step_003_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Action] Tap btnHome at (53.6%, 34.1%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'btnHome', 53.6, 34.1)\n    assert True\n"
