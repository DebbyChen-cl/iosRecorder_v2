  "step_000_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Action] Tap Edit at (42.9%, 47.4%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'Edit', 42.9, 47.4, container_by=AppiumBy.XPATH, container_value='//XCUIElementTypeOther[@name=\"LauncherProViewController\"]/XCUIElementTypeScrollView', container_w=320, container_h=539)\n    assert True\n",
  "step_001_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Action] Tap photoCell-0 at (51.0%, 33.3%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'photoCell-0', 51.0, 33.3, container_by=AppiumBy.ACCESSIBILITY_ID, container_value='photoCollectionView', container_w=320, container_h=557)\n    assert True\n",
  "step_002_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Action] Tap btn top home n at (60.0%, 55.0%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'btn top home n', 60.0, 55.0)\n    assert True\n"
