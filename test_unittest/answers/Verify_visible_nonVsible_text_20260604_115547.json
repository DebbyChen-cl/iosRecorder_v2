  "step_000_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Action] Tap btnSettings at (76.0%, 53.8%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'btnSettings', 76.0, 53.8)\n    assert True\n",
  "step_001_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Verify] Sign in is visible\"):\n        actions.verify_visible(AppiumBy.ACCESSIBILITY_ID, 'Sign in')\n    assert True\n",
  "step_002_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Verify] Sign in text equals 'Sign in'\"):\n        actions.verify_text(AppiumBy.ACCESSIBILITY_ID, 'Sign in', 'Sign in')\n    assert True\n",
  "step_003_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Action] Tap btnBack at (61.9%, 54.3%)\"):\n        actions.tap_within_element(AppiumBy.ACCESSIBILITY_ID, 'btnBack', 61.9, 54.3)\n    assert True\n",
  "step_004_t5": "import pytest\nfrom appium.webdriver.common.appiumby import AppiumBy\nfrom reportportal_client import step\n\nfrom driver.driver_actions import DriverActions\n\n\n@pytest.mark.name(\"test_case\")\ndef test_test_case(actions: DriverActions):\n    with step(\"[Verify] Sign in is not visible\"):\n        actions.verify_not_visible(AppiumBy.ACCESSIBILITY_ID, 'Sign in')\n    assert True\n",
